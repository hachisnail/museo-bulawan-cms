# =====================================================================
# Payload CMS — environment template
# Copy this file to `.env` (same folder) and fill in real values.
# Never commit `.env`. Only this `.env.example` is committed.
# =====================================================================

# --- REQUIRED ---------------------------------------------------------

# Long random string used to sign Payload session tokens.
# Generate one with: openssl rand -hex 32
# DO NOT keep the placeholder in any non-dev environment.
PAYLOAD_SECRET=replace-me-with-openssl-rand-hex-32

# Database connection. Default = local SQLite file (good for dev).
# For production, consider switching to Postgres and using
# @payloadcms/db-postgres in payload.config.ts.
DATABASE_URI=file:./data/payload.db

# --- OPTIONAL: PUBLIC URLS -------------------------------------------

# Public URL where this Payload instance is reachable.
# Used by the admin UI for absolute links and by other apps for fetches.
PAYLOAD_PUBLIC_SERVER_URL=http://localhost:3001

# --- OPTIONAL: S3 / MinIO STORAGE ------------------------------------
# Uncomment and fill these when wiring uploads to MinIO via
# @payloadcms/storage-s3 (see payload_cms_astro_integration.md §5.B).

# S3_ENDPOINT=http://localhost:9000
# S3_BUCKET=museo-cms
# S3_REGION=us-east-1
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
# S3_FORCE_PATH_STYLE=true

# --- OPTIONAL: SMTP (transactional email) ----------------------------
# Used if/when Payload sends password-reset or notification emails.

# SMTP_HOST=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=no-reply@museobulawan.example
# SMTP_FROM_NAME=Museo Bulawan CMS

# --- OPTIONAL: NODE ENVIRONMENT --------------------------------------
NODE_ENV=development
