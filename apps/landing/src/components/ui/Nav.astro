---
import Logo from '../../assets/LOGO.png';

interface Props {
  theme?: "light" | "dark";
}

const { theme = "light" } = Astro.props;
const currentPath = Astro.url.pathname;

// Removed catalogs_public
const flags = {
  home: true,
  articles_public: true,
  about: true,
};

const bgClass = theme === "dark" ? "bg-transparent border-white" : "bg-transparent border-black";
const textClass = theme === "dark" ? "text-white" : "text-black";
const dividerClass = theme === "dark" ? "bg-transparent" : "bg-gray-700";
const activeBorderClass = `border-b-2 border-yellow-500 ${theme === "dark" ? "text-white" : "text-black"}`;

const isActive = (path: string) => currentPath === path || (path !== "/" && currentPath.startsWith(path));

const navItems = [
  {
    show: flags.home,
    to: "/",
    label: "Home",
    title: "Go to Home Page",
    dropdownKey: "home",
    anchorpoints: [
      { label: "Learn More", value: "learn_more" },
      { label: "Whats On?", value: "whats_on" },
      { label: "News & Events", value: "news_events" },
      { label: "Support", value: "support" },
    ]
  },
  {
    show: flags.articles_public,
    to: "/articles",
    label: "News & Events",
    title: "View News & Events",
    dropdownKey: null,
    anchorpoints: []
  },
  {
    show: flags.about,
    to: "/about",
    label: "About",
    title: "Learn About Museo Bulawan",
    dropdownKey: "about",
    anchorpoints: []
  }
];
---

<nav
  id="main-navbar-top" 
  class={`w-full max-w-[140rem] mx-auto flex items-center justify-between px-8 md:px-16 lg:px-32 py-2 border-b-2 ${bgClass}`}
>
  <div class="flex items-center gap-x-5">
    <a href="/" title="Home">
      <img src={Logo.src} alt="Museo Bulawan Logo" class="w-16" />
    </a>
    <div class="flex items-center gap-x-2">
      <i class={`h-12 w-1 rounded-sm ${dividerClass}`}></i>
      <a href="/" class={`flex flex-col text-2xl justify-center ${textClass}`}>
        <span class="font-bold leading-6">Museo</span>
        <span class="font-bold leading-6">Bulawan</span>
      </a>
    </div>
  </div>

  <div class="flex items-center gap-x-4">
    {navItems.filter(item => item.show).map((item) => (
      <div class="relative w-fit flex items-center gap-x-1 dropdown-container">
        
        <a
          title={item.title}
          href={item.to}
          class={`px-3 py-1 transition-all duration-200 font-semibold text-lg hover:opacity-80 ${isActive(item.to) ? activeBorderClass : textClass}`}
        >
          {item.label}
        </a>

        {item.anchorpoints.length > 0 && (
          <>
            <button
              class="text-lg cursor-pointer dropdown-toggle p-1 hover:text-yellow-500 transition-colors"
              title="Toggle section dropdown"
              data-target={`dropdown-${item.dropdownKey}`}
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                class={`transition-transform duration-200 carret-icon ${textClass}`}
              >
                <path d="M6 9l6 6l6 -6" />
              </svg>
            </button>

            <div 
              id={`dropdown-${item.dropdownKey}`}
              class={`hidden absolute top-full mt-2 right-0 backdrop-blur-md border rounded shadow z-40 w-44 flex-col ${theme === 'dark' ? "border-white bg-[#1C1B19]/90" : "border-black bg-white/90"}`}
            >
              {item.anchorpoints.map((anchor) => (
                <a
                  href={`${item.to === '/' ? '' : item.to}#${anchor.value}`}
                  class={`block cursor-pointer px-4 py-2 text-center ${textClass} hover:bg-white/20 hover:text-yellow-400 rounded text-sm w-full transition-colors`}
                >
                  {anchor.label}
                </a>
              ))}
            </div>
          </>
        )}
      </div>
    ))}
  </div>
</nav>

<script>
  const dropdownToggles = document.querySelectorAll<HTMLElement>('.dropdown-toggle');
  const allDropdowns = document.querySelectorAll<HTMLElement>('div[id^="dropdown-"]');
  const allCarrets = document.querySelectorAll<HTMLElement>('.carret-icon');

  const closeAllDropdowns = () => {
    allDropdowns.forEach(menu => { menu.classList.add('hidden'); menu.classList.remove('flex'); });
    allCarrets.forEach(icon => { icon.style.transform = "rotate(0deg)"; });
  };

  dropdownToggles.forEach(toggle => {
    toggle.addEventListener('click', (e) => {
      e.stopPropagation(); 
      const targetId = toggle.getAttribute('data-target');
      if (!targetId) return; 

      const targetMenu = document.getElementById(targetId);
      const carret = toggle.querySelector<HTMLElement>('.carret-icon');
      const isCurrentlyHidden = targetMenu?.classList.contains('hidden');

      closeAllDropdowns(); 

      if (isCurrentlyHidden && targetMenu && carret) {
        targetMenu.classList.remove('hidden');
        targetMenu.classList.add('flex');
        carret.style.transform = "rotate(180deg)";
      }
    });
  });

  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('.dropdown-container')) { closeAllDropdowns(); }
  });
</script>